AMANI_DATABASE_URL=sqlite:///./amani_circle.sqlite3
AMANI_BOOTSTRAP_ADMIN_USERNAME=admin
AMANI_BOOTSTRAP_ADMIN_EMAIL=admin@example.test
AMANI_BOOTSTRAP_ADMIN_PASSWORD=replace-this-admin-password
AMANI_DEFAULT_RESPONDER_USERNAME=responder
AMANI_DEFAULT_RESPONDER_EMAIL=responder@example.test
AMANI_DEFAULT_RESPONDER_PASSWORD=replace-this-responder-password
AMANI_SESSION_SECRET=replace-this-long-random-secret
AMANI_SESSION_COOKIE_NAME=amani_responder_session
AMANI_SESSION_TTL_SECONDS=28800
AMANI_SESSION_COOKIE_SECURE=false
AMANI_DASHBOARD_BASE_URL=http://127.0.0.1:5173/#responder
AMANI_FOLLOWUP_RATE_WINDOW_SECONDS=300
AMANI_FOLLOWUP_RATE_ATTEMPTS=5
AMANI_PUBLIC_BUCKET_THRESHOLD=3
AMANI_MEDIA_UPLOAD_DIR=./media_uploads
AMANI_MEDIA_MAX_UPLOAD_BYTES=10485760
AMANI_MEDIA_DEV_MARK_CLEAN=true
